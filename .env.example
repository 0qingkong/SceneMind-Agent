# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Backend
APP_NAME=SceneMind Agent
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ANALYZER_MODE=yolo
YOLO_MODEL=yolo26n.pt
YOLO_CONF=0.30
YOLO_IMGSZ=640
YOLO_MAX_DET=30
YOLO_DEVICE=auto
SPATIAL_ENABLED=true
SPATIAL_NEAR_THRESHOLD=0.25
SPATIAL_OVERLAP_IOU_THRESHOLD=0.05
SPATIAL_CONTAINMENT_THRESHOLD=0.90
SPATIAL_AXIS_SEPARATION_THRESHOLD=0.08
SPATIAL_MAX_RELATIONS=80
DATABASE_URL=sqlite:///./data/scenemind.db
SCENE_STORAGE_DIR=./data/images
OBSERVATION_DEFAULT_LIMIT=20
OBSERVATION_MAX_LIMIT=100
MEMORY_HISTORY_DEFAULT_LIMIT=20
MEMORY_HISTORY_MAX_LIMIT=100
MEMORY_RELATION_CONTEXT_LIMIT=8
AGENT_DEFAULT_LIMIT=3
AGENT_MAX_LIMIT=20
DEMO_MODE=false
CAPTURE_DEFAULT_INTERVAL_SECONDS=5
CAPTURE_MIN_INTERVAL_SECONDS=3
CAPTURE_MAX_INTERVAL_SECONDS=60
CAPTURE_MIN_SAVE_GAP_SECONDS=15
CAPTURE_OBJECT_COUNT_DELTA=2
CAPTURE_MAX_SESSION_MINUTES=60

# Browser capture (frontend build-time)
VITE_CAPTURE_IMAGE_TYPE=image/jpeg
VITE_CAPTURE_JPEG_QUALITY=0.88
VITE_CAPTURE_MAX_WIDTH=1600
